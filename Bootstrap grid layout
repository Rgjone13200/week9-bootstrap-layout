<!-- Hero Section with Bootstrap Grid -->
  <section id="home" class="hero py-5">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-7 text-center text-lg-start">
          <h1 class="display-4 fw-bold text-warning">Enter the Ultimate Comic Con Experience</h1>
          <p class="lead text-light mt-3">
            Explore a world of comics, cosplay, gaming, and fandom with exciting events,
            special guests, and unforgettable convention moments.
          </p>
          <a href="#events" class="btn btn-danger btn-lg mt-3">Explore Events</a>
        </div>

        <div class="col-lg-5 text-center">
          <div class="p-4 rounded shadow-lg bg-dark border border-info">
            <h3 class="text-info fw-bold">This Year’s Highlights</h3>
            <ul class="list-unstyled mt-3 text-light">
              <li>Cosplay Championship</li>
              <li>Artist Alley</li>
              <li>Gaming Arena</li>
              <li>Celebrity Panels</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>


<!-- Interactive Section with Bootstrap Grid -->
  <section id="guests" class="py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 text-center">
          <div class="p-5 bg-dark border border-warning rounded shadow">
            <h2 class="text-info fw-bold mb-3">Special Guest Reveal</h2>
            <p class="text-light mb-4">
              Click the button below to reveal one of the featured guests appearing at ComicVerse Con.
            </p>

            <button
              type="button"
              class="btn btn-info btn-lg fw-bold"
              data-bs-toggle="modal"
              data-bs-target="#guestModal"
            >
              Reveal Guest
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

 <!-- Events Section with Bootstrap Grid -->
